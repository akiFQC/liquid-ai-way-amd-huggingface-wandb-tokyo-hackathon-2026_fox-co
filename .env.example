# HuggingFace token. Use a fine-grained token with WRITE access to model + dataset
# repos in your namespace — default tokens are read-only and PUSH_TO_HUB will fail
# with a 403.
# https://huggingface.co/settings/tokens
HF_TOKEN=<YOUR HF_TOKEN>

# Claim your $150 hackathon credit (sign up with the same email you used to register for the hackathon).
# The claim link is shared with registered teams. Verify the credit landed:
# https://huggingface.co/settings/billing

# Weights & Biases API key
# https://wandb.ai/authorize
WANDB_API_KEY=<YOUR WANDB_API_KEY>

# Your W&B entity. By default this is your W&B username — find it at
# https://wandb.ai/home (top-left, under your avatar). Override only if
# you want runs to land in a team / org you belong to instead.
WANDB_ENTITY=<YOUR WANDB_ENTITY>

# Project name (auto-created on first run if it doesn't already exist).
WANDB_PROJECT=hack-the-liquid-way
